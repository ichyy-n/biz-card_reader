# LINE Bot credentials
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# Google OAuth
CRYPT_KEY=your_fernet_key
CLIENT_SECRET_PATH=/path/to/client_secret.json
FOLDER_ID=your_google_drive_folder_id
SHEET_ID=your_google_spreadsheet_id

# Database
SQL_URL=sqlite:///./users.db

# OpenAI (標準環境変数名: OPEN_API_KEY から変更)
OPENAI_API_KEY=sk-xxxx

# Session security (固定値を設定: openssl rand -hex 32 で生成)
SESSION_SECRET_KEY=your_fixed_session_secret_key

# Whitelist: 許可するLINEユーザーIDをカンマ区切りで列挙
ALLOWED_LINE_USERS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
